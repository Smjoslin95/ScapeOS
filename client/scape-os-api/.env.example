# ── PostgreSQL (Railway auto-fills these) ────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
CLIENT_ORIGIN=http://localhost:5173

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Paste the entire JSON from your Firebase service account key as ONE line
# (or set individual vars — see src/middleware/auth.js for details)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
